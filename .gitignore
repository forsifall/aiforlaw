# В корне репозитория в Git попадают только:
#   package.json, package-lock.json, webpack.config.js, .gitignore, папка src/
# Всё остальное в корне — нет (copy_assets, css_html_helper, архивы и т.д.)

/*
!/.gitignore
!/package.json
!/package-lock.json
!/webpack.config.js
!/src/
!/src/**

node_modules/
dist/

# Явно (дублирует логику /*, но понятно что это не часть проекта)
copy_assets/
css_html_helper/

*.zip

cursor_rules.txt

# Логи / окружение / мусор
*.log
.env
.env.*.local
.DS_Store
Thumbs.db
.idea/
